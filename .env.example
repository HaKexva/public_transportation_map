# Required in production (or when config/master.key is unavailable).
# Generate with: bin/rails secret
SECRET_KEY_BASE=

# Alternative to config/master.key for decrypting credentials.yml.enc
# RAILS_MASTER_KEY=

# PostgreSQL connection (required in production).
# Example: postgres://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=

# Optional overrides for local development (when DATABASE_URL is unset):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_NAME=public_transportation_map_development

# Optional: separate databases for Solid Cache / Queue / Cable (defaults to DATABASE_URL)
# CACHE_DATABASE_URL=
# QUEUE_DATABASE_URL=
# CABLE_DATABASE_URL=

# Optional: Google Maps (requires billing / credit card on Google Cloud)
# The app uses OpenStreetMap by default — no key needed.
GOOGLE_MAPS_API_KEY=
